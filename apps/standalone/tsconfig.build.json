{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src/index.ts", "src/lib", "src/crdt", "src/bundle.ts"],
  "exclude": ["dist", "node_modules", "src/**/*.test.ts", "src/**/*.test.tsx", "e2e"]
}
