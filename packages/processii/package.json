{
  "name": "@binarii/processii",
  "version": "0.10.0",
  "description": "CRDT-backed process whiteboard engine and React editing surface — Yjs board, Canvas 2D renderer, pluggable transport/persistence, Excalidraw/draw.io interop.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/binarii-io/processii.git",
    "directory": "packages/processii"
  },
  "homepage": "https://github.com/binarii-io/processii#readme",
  "bugs": "https://github.com/binarii-io/processii/issues",
  "keywords": [
    "whiteboard",
    "yjs",
    "crdt",
    "process",
    "collaboration",
    "offline-first",
    "canvas",
    "react"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "default": "./dist/core.js"
    },
    "./agent-ops": {
      "types": "./dist/agent-ops.d.ts",
      "default": "./dist/agent-ops.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "default": "./dist/ui/index.js"
    },
    "./styles.css": "./src/ui/styles/theme.css",
    "./tailwind-preset": {
      "types": "./dist/ui/tailwind-preset.d.ts",
      "default": "./dist/ui/tailwind-preset.js"
    }
  },
  "files": [
    "dist",
    "src/ui/styles"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "tailwind-merge": "^2.6.0",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.31",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  }
}
